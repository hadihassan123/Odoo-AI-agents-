APP_NAME=AI Studio Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=/api/v1
LOG_LEVEL=INFO
ENABLE_DOCS=true

DATABASE_URL=sqlite:///./ai_studio.db
SERVICE_API_KEY=change-this-before-odoo-connects

GROQ_API_KEY=
OPENROUTER_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=google/gemma-3n-e4b-it:free

AI_REQUEST_TIMEOUT=30
AI_REQUEST_RETRIES=3
AI_RETRY_DELAY_SECONDS=1.5

CORS_ORIGINS=http://localhost:8069,http://127.0.0.1:8069
