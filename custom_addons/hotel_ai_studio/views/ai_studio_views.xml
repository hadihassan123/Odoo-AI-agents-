<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="ai_studio_form_view" model="ir.ui.view">
            <field name="name">ai.studio.chat.form</field>
            <field name="model">ai.studio.chat</field>
            <field name="arch" type="xml">
                <form string="Hotel AI Studio" create="false" delete="false">
                    <sheet>
                        <div class="ai_studio_screen_root"/>

                        <div class="ai_studio_fallback">
                            <div class="ai_studio_header">
                                <h2>Hotel AI Studio</h2>
                                <p>Frontend is loading. If tabwhich may be duplics do not appear, you can still use the fallback chat below.</p>
                            </div>

                            <div class="ai_studio_fallback_mode">
                                <field name="chat_mode" widget="radio" options="{'horizontal': true}" nolabel="1"/>
                            </div>

                            <div class="ai_slave_hint" invisible="chat_mode != 'slave'">
                                <p><b>Slave Mode</b>: type <b>start</b> to begin module creation.</p>
                            </div>

                            <div class="ai_studio_fallback_history">
                                <field name="response" readonly="1" nolabel="1" placeholder="Responses will appear here in fallback mode."/>
                            </div>

                            <div class="ai_studio_fallback_composer">
                                <field name="message" placeholder="Type your message here..." nolabel="1"/>
                                <button name="action_send" string="Send" type="object" class="btn-primary"/>
                            </div>
                        </div>

                        <group invisible="1">
                            <field name="history"/>
                            <field name="chat_history"/>
                            <field name="slave_step"/>
                            <field name="slave_data"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="ai_studio_action" model="ir.actions.act_window">
            <field name="name">AI Studio</field>
            <field name="res_model">ai.studio.chat</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
